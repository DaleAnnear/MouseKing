#!/usr/bin/bash

# Main script to manage and execute MouseKing 
# Author: Dale J. Annear, PhD
# Date: 2025/01/23

globdir=$(dirname "$(realpath "$0")")

# Function to run commands
run_command() {
    command="$1"
    echo "Running command: $command"
    
    # Execute the command, streaming to both terminal and log
    eval "$command" 2>&1 
    
    # Capture the exit status
    status=${PIPESTATUS[0]}  # Ensure we capture the correct exit status
    if [ $status -eq 0 ]; then
        echo "Command completed successfully."
    else
        echo "Command failed with exit status $status."
    fi
}

# MouseKing class-like behavior
MouseKing() {
    command="$1"
    shift

    case "$command" in
        royale)
            royale "$@"
            ;;
        integrity)
            integrity "$@"
            ;;
        rebuild)
            rebuild "$@"
            ;;
        extract)
            extract "$@"
            ;;
        processing)
            processing "$@"
            ;;
        uni)
            uni "$@"
            ;;
        multi)
            uni "$@"
            ;;
        install)
            install "$@"
            ;;                     
        *)
            echo "Unrecognized command"
            print_help
            exit 1
            ;;
    esac
}

# Function for 'royale' command
royale() {
     if [[ -z "$1" || "$1" == "--help" ]]; then
        echo "Usage: MouseKing royale [options]"
        echo ""
        echo "Options:"
        echo "  -i  Input file containg full paths to LMT SQlite files to be processed (required)"
        echo "  -m  File path to the mouse cage manifest (required)"
        echo "  -s  Save name for the batch of SQlite files to be processed (required)"
        echo "  -o  Path to the desired output directory (required)"
        echo "  -f  Frame filter - DEFAULT RECOMMENDED (default: 15)"
        echo "  -t  Time file - DEFAULT RECOMMENDED (default: NULL)"
        echo "  -d  Reference group for effect size calculation (Cohen D value) - DEFAULT RECOMMENDED (default: NULL)"
        echo "  -r  Rebuild (default: TRUE)"
        echo ""
        echo "Example:"
        echo "  MouseKing royale -i ~/Example/data/input.txt -m ~/Example/data/Example_manifest.txt -s MouseKing_Example -o ~/Example/results"
        echo ""
        echo "NOTE: Full paths must be provided"
        return
    fi

    while getopts "i:m:s:o:f:t:d:r:" opt; do
        case "$opt" in
            i) input_file="$OPTARG" ;;
            m) manifest="$OPTARG" ;;
            s) save_name="$OPTARG" ;;
            o) output="$OPTARG" ;;
            f) frame_filter="$OPTARG" ;;
            t) time_file="$OPTARG" ;;
            d) effect_reference="$OPTARG" ;;
            r) rebuild="$OPTARG" ;;
            *) echo "Invalid option"; exit 1 ;;
        esac
    done

    frame_filter="${frame_filter:-15}"
    time_file="${time_file:-NULL}"
    effect_reference="${effect_reference:-NULL}"
    rebuild="${rebuild:-"TRUE"}"

    if [[ -z "$input_file" || -z "$manifest" || -z "$save_name" || -z "$output" ]]; then
        echo "Error: One or more required argument are missing. Please see --help for usage."
        return 1
    fi

    echo "######    Performing full MouseKing pipeline  ######"
    if [ "$rebuild" == "TRUE" ]; then
        run_cmd="nextflow run '$globdir/Nextflow/MouseKing_main.nf' --input_file '$input_file' --manifest '$manifest' --save_name '$save_name' --output '$output' --time_file '$time_file' --ref '$effect_reference' --event_frame_filter '$frame_filter'"
    elif [ "$rebuild" == "FALSE" ]; then
        run_cmd="nextflow run '$globdir/Nextflow/MouseKing_norebuild.nf' --input_file '$input_file' --manifest '$manifest' --save_name '$save_name' --output '$output' --time_file '$time_file' --ref '$effect_reference' --event_frame_filter '$frame_filter'"
    fi    
    run_command "$run_cmd"
}

